{
  "manifest_version": 3,
  "name": "Tracr",
  "description": "Add job applications to Tracr from any job posting page.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://localhost:3000/*", "https://tracr-web.vercel.app/*"]
}
